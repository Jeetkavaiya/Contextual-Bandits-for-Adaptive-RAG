%% Two-phase training pipeline
%% Matches precompute_rewards.py + train_bandit.py
flowchart TB
    subgraph P0["Phase 0: Indexing (one time)"]
        PDF["PDF<br/>data/prudentservices_dataset_rag.pdf"] --> CH["125 chunks<br/>(450 tokens, 80 overlap)"]
        CH --> BMI["BM25 Index"]
        CH --> DEI["Dense Index<br/>(FAISS + nomic-embed-text)"]
    end

    subgraph P1["Phase 1: Reward Precompute (GPU on CCR)"]
        EVAL["Eval set<br/>100 items, 70 in-domain + 30 OOD"] --> LOOP["For each item i in 100:<br/>For each action a in 54:"]
        BMI --> LOOP
        DEI --> LOOP
        LOOP --> RAG1["Run RAG pipeline<br/>with config(a)"]
        RAG1 --> JUDGE1["LLM Judge scores<br/>correctness, faithfulness, recall"]
        JUDGE1 --> RW["Compute scalar reward<br/>r(i,a)"]
        RW --> TBL["Reward Table<br/>R in R^(100 x 54)<br/>+ States S in R^(100 x 11)"]
    end

    subgraph P2["Phase 2: Bandit Training (CPU)"]
        TBL --> SAMP["Sample query i ~ Uniform"]
        SAMP --> SEL["Agent selects arm a<br/>(LinUCB or Thompson)"]
        SEL --> OBS["Observe r(i,a) from table"]
        OBS --> UPD["Update agent params"]
        UPD -->|5000 steps| SAMP
        UPD --> CKPT["Save checkpoint<br/>(.pkl)"]
    end

    P0 --> P1
    P1 --> P2

    classDef phase fill:#eef9ee,stroke:#2f7c33,stroke-width:1px,color:#10381a;
    classDef step fill:#eaf3ff,stroke:#3b6db5,stroke-width:1px,color:#0d2b59;
    classDef io fill:#fff3cd,stroke:#b58a00,stroke-width:1px,color:#5a3e00;
    class PDF,EVAL,CKPT,TBL io;
    class CH,BMI,DEI,LOOP,RAG1,JUDGE1,RW,SAMP,SEL,OBS,UPD step;
